# Copy this file to ".env" and fill in what you have. Everything is optional
# to START — the app runs in preview mode with no email configured.

# What shows on emails and the top bar
RESTAURANT_NAME=Your Restaurant

# Port the app runs on
PORT=4000

# --- Benugin webhook -------------------------------------------------------
# A long random string. Give the SAME value to the Benugin developer; the app
# rejects any POST to /webhook/benugin that doesn't send it.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
WEBHOOK_SECRET=

# --- Email (leave blank to stay in preview mode) ---------------------------
# EASIEST: a Gmail App Password (not your normal password).
# Google account → Security → 2-Step Verification → App passwords.
GMAIL_USER=malekqibaa@gmail.com
GMAIL_APP_PASSWORD=
MAIL_FROM=malekqibaa@gmail.com

# OR a generic SMTP server instead of Gmail:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# --- Photo-of-report reader (optional) -------------------------------------
# Lets you snap the end-of-day POS report and have it fill in each server's
# sales + card tips automatically. Uses Claude's vision API — get a key at
# console.anthropic.com. Costs roughly a cent or two per report read.
ANTHROPIC_API_KEY=
# Optional: use a cheaper/faster model for reading (default is claude-opus-4-8):
# READER_MODEL=claude-sonnet-5
